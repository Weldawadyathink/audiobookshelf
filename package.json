{
  "name": "audiobookshelf",
  "version": "2.33.0",
  "buildNumber": 1,
  "description": "Self-hosted audiobook and podcast server",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch index.js -- --dev",
    "start": "tsx index.js",
    "start-dev": "tsx index.js --prod-with-dev-env",
    "client": "cd client && npm ci && npm run generate",
    "prod": "npm run client && npm ci && tsx index.js",
    "typecheck": "tsc --noEmit",
    "build:compile": "tsc -p tsconfig.build.json",
    "build:copy": "node -e \"const fs=require('fs'); fs.cpSync('server/libs','dist/server/libs',{recursive:true}); fs.cpSync('server/migrations','dist/server/migrations',{recursive:true})\"",
    "build-win": "npm run client && npm run build:compile && npm run build:copy && pkg -t node20-win-x64 -o ./dist/win/audiobookshelf -C GZip .",
    "build-win-no-compress": "npm run client && pkg -t node20-win-x64 -o ./dist/win/audiobookshelf .",
    "build-linux": "build/linuxpackager",
    "docker": "docker buildx build --platform linux/amd64,linux/arm64 --push .  -t advplyr/audiobookshelf",
    "docker-amd64-local": "docker buildx build --platform linux/amd64 --load .  -t advplyr/audiobookshelf-amd64-local",
    "docker-arm64-local": "docker buildx build --platform linux/arm64 --load .  -t advplyr/audiobookshelf-arm64-local",
    "deploy-linux": "node deploy/linux",
    "test": "mocha",
    "coverage": "nyc mocha"
  },
  "bin": "index.js",
  "pkg": {
    "assets": [
      "client/dist/**/*",
      "node_modules/sqlite3/lib/binding/**/*.node",
      "dist/server/migrations/*.js"
    ],
    "scripts": [
      "dist/server/**/*.js"
    ]
  },
  "author": "advplyr",
  "license": "GPL-3.0",
  "dependencies": {
    "axios": "^0.27.2",
    "cookie-parser": "^1.4.6",
    "express": "^4.17.1",
    "express-rate-limit": "^7.5.1",
    "express-session": "^1.17.3",
    "graceful-fs": "^4.2.10",
    "htmlparser2": "^8.0.1",
    "lru-cache": "^10.0.3",
    "node-unrar-js": "^2.0.2",
    "nodemailer": "^6.9.13",
    "openid-client": "^5.6.1",
    "p-throttle": "^4.1.1",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "semver": "^7.6.3",
    "sequelize": "^6.35.2",
    "socket.io": "^4.5.4",
    "sqlite3": "^5.1.7",
    "ssrf-req-filter": "^1.1.0",
    "xml2js": "^0.5.0"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/sinon": "^21.0.0",
    "@types/xml2js": "^0.4.14",
    "chai": "^4.3.10",
    "mocha": "^10.2.0",
    "nodemon": "^2.0.20",
    "nyc": "^15.1.0",
    "sinon": "^17.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
