{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],

    "noEmit": true,
    "outDir": "./dist",

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    "allowJs": true,
    "checkJs": true,
    "maxNodeModuleJsDepth": 0,

    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,

    "skipLibCheck": true,
    "sourceMap": true,
    "inlineSources": true
  },
  "include": [
    "index.js",
    "server/**/*.ts",
    "server/**/*.js",
    "test/**/*.ts",
    "test/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "client",
    "dist",
    "server/libs"
  ]
}
